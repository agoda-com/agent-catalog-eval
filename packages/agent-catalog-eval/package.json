{
  "name": "agoda-agent-catalog-eval",
  "version": "0.1.0",
  "description": "CLI to evaluate coding-agent skills against a catalog of test cases.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agent-catalog-eval": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "openai": "6.35.0",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.6.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "url": "https://github.com/agoda-com/agent-catalog-eval"
  },
  "keywords": [
    "skills",
    "agents",
    "evaluation",
    "cli",
    "opencode",
    "claude-code",
    "cursor"
  ],
  "license": "Apache-2.0"
}
